// Prisma schema for NULL FORM — TerminalIntel ledger
// Runtime client uses @prisma/client/edge + withAccelerate (Workers-safe).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IntelClassification {
  PUBLIC
  RESTRICTED
  CLASSIFIED
  REDACTED
}

model TerminalIntel {
  id             String              @id @default(cuid())
  slot           Int?
  headline       String
  body           String
  // JSON array of { start: number, end: number } spans into `body`.
  redactedSpans  Json                @default("[]")
  classification IntelClassification @default(RESTRICTED)
  createdAt      DateTime            @default(now())

  @@index([createdAt])
}
