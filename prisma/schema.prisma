generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum IntelClassification {
  PUBLIC
  RESTRICTED
  CLASSIFIED
  REDACTED
}

model TerminalIntel {
  id             String              @id @default(cuid())
  slot           Int?
  headline       String
  body           String
  // JSON array of { start: number, end: number } character spans into `body`.
  redactedSpans  Json                @default("[]")
  classification IntelClassification @default(RESTRICTED)
  createdAt      DateTime            @default(now())

  @@index([createdAt])
}
